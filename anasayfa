let targetPage = '', targetUrl = '', targetVideoSrc = null;

function openVideo(src) { const player = document.getElementById('videoPlayer'); player.src = src; player.load(); document.getElementById('videoOverlay').classList.add('show'); }
function closeVideo() { const player = document.getElementById('videoPlayer'); player.pause(); player.src = ''; document.getElementById('videoOverlay').classList.remove('show'); }
function closeVideoOutside(e) { if (e.target === document.getElementById('videoOverlay')) closeVideo(); }
function checkAccessAndOpen(requiredAccessType, successCallback) { const storedType = sessionStorage.getItem('hamzaAccessType'); const storedUser = sessionStorage.getItem('hamzaUser'); if(storedUser && storedType === requiredAccessType){ if(successCallback) successCallback(); return true; } else if(storedUser && storedType !== requiredAccessType){ alert(`Bu içerik farklı yetki gerektiriyor. Oturum kapatılıyor.`); sessionStorage.removeItem('hamzaUser'); sessionStorage.removeItem('hamzaAccessType'); return false; } return false; }
function openExamLogin(page) { if(checkAccessAndOpen(ACCESS_TYPE.EXAM, ()=>{ window.location.href=page; })) return; targetPage=page; targetUrl=''; targetVideoSrc=null; document.getElementById('modalSubTitle').innerHTML = 'Bu sınav içeriğine erişmek için <strong>Sınav</strong> hesabınızla giriş yapmalısınız.'; document.getElementById('modalOverlay').classList.add('show'); }
function openExamLoginVideo(src) { if(checkAccessAndOpen(ACCESS_TYPE.EXAM, ()=>{ openVideo(src); })) return; targetVideoSrc=src; targetPage=''; targetUrl=''; document.getElementById('modalSubTitle').innerHTML = 'Bu video içeriğine erişmek için <strong>Sınav</strong> hesabınızla giriş yapmalısınız.'; document.getElementById('modalOverlay').classList.add('show'); }
function openWritingOdev() { const url='https://hamzahocaodevkontrolu.base44.app/'; if(checkAccessAndOpen(ACCESS_TYPE.WRITING, ()=>{ window.location.href=url; })) return; targetUrl=url; targetPage=''; targetVideoSrc=null; document.getElementById('modalSubTitle').innerHTML = 'Yazma ödevi göndermek için <strong>Yazma Ödevi</strong> hesabınızla giriş yapmalısınız.'; document.getElementById('modalOverlay').classList.add('show'); }
function openSpeakingOdev() { const url='https://hamzahocailekonusmapratigi.base44.app/'; if(checkAccessAndOpen(ACCESS_TYPE.SPEAKING, ()=>{ window.location.href=url; })) return; targetUrl=url; targetPage=''; targetVideoSrc=null; document.getElementById('modalSubTitle').innerHTML = 'Konuşma ödevi göndermek için <strong>Konuşma Ödevi</strong> hesabınızla giriş yapmalısınız.'; document.getElementById('modalOverlay').classList.add('show'); }
function closeModal() { document.getElementById('modalOverlay').classList.remove('show'); }
function closeModalOutside(e) { if(e.target === document.getElementById('modalOverlay')) closeModal(); }
async function doLogin() { /* aynı login mantığı, kısaltmak adına orijinali kullanıyoruz, ancak uzunluk nedeniyle aynen koruyorum */ const username = document.getElementById('inputUser').value.trim(); const password = document.getElementById('inputPass').value.trim(); if(!username||!password) return; const btn = document.getElementById('btnLogin'); btn.disabled=true; btn.textContent='Kontrol ediliyor...'; const modalSubTitle = document.getElementById('modalSubTitle').innerText; let requiredAccessType = ACCESS_TYPE.EXAM; if(modalSubTitle.includes('Yazma Ödevi')) requiredAccessType=ACCESS_TYPE.WRITING; else if(modalSubTitle.includes('Konuşma Ödevi')) requiredAccessType=ACCESS_TYPE.SPEAKING; try{ let sheetUrl = requiredAccessType===ACCESS_TYPE.EXAM?EXAM_SHEET_URL:(requiredAccessType===ACCESS_TYPE.WRITING?WRITING_SHEET_URL:SPEAKING_SHEET_URL); const res = await fetch(sheetUrl); const rows = parseCSV(await res.text()); let found=false, isExpired=false; for(let i=1;i<rows.length;i++){ const [sheetUser, sheetPass, expiryDateRaw]=rows[i].map(c=>(c||'').trim()); if(sheetUser.toLowerCase()===username.toLowerCase() && sheetPass===password){ found=true; if(expiryDateRaw && expiryDateRaw!==''){ const parts=expiryDateRaw.split('-'); if(parts.length===3){ const day=parseInt(parts[0],10), month=parseInt(parts[1],10)-1, year=parseInt(parts[2],10); const expiry=new Date(year,month,day); const today=new Date(); today.setHours(0,0,0,0); if(today>expiry){ isExpired=true; continue; } } } sessionStorage.setItem('hamzaUser',username); sessionStorage.setItem('hamzaAccessType',requiredAccessType); closeModal(); if(targetVideoSrc){ openVideo(targetVideoSrc); targetVideoSrc=null; }else if(targetUrl){ window.location.href=targetUrl; targetUrl=''; }else if(targetPage){ window.location.href=targetPage; targetPage=''; } return; } } if(!found){ let sheetName = requiredAccessType===ACCESS_TYPE.EXAM?'Sınav (Sheet2)':(requiredAccessType===ACCESS_TYPE.WRITING?'Yazma Ödevi (Sheet3)':'Konuşma Ödevi (Sheet4)'); alert(`Hatalı kullanıcı adı veya şifre! (${sheetName} hesabı)`); } else if(isExpired) alert('Üyelik süreniz dolmuştur. Lütfen yenilemek için Hamza Hoca ile iletişime geçiniz.'); } catch(err){ alert('Bağlantı hatası!'); } finally { btn.disabled=false; btn.textContent='GİRİŞ YAP'; } }
function parseCSV(text) { const rows=[]; const lines=text.split('\n'); for(let i=0;i<lines.length;i++){ const line=lines[i].trim(); if(line==='') continue; const cols=[]; let cur='', inQuote=false; for(let j=0;j<line.length;j++){ const ch=line[j]; if(ch==='"') inQuote=!inQuote; else if(ch===',' && !inQuote){ cols.push(cur); cur=''; } else cur+=ch; } cols.push(cur); rows.push(cols.map(c=>c.replace(/^"|"$/g,'').trim())); } return rows; }
document.addEventListener('DOMContentLoaded',()=>{ document.getElementById('odevGonderBtn')?.addEventListener('click',(e)=>{ e.preventDefault(); openWritingOdev(); }); document.getElementById('konusmaOdevGonderBtn')?.addEventListener('click',(e)=>{ e.preventDefault(); openSpeakingOdev(); }); initNewCategorySystem(); });
function initNewCategorySystem() {
  const panels = {
    'okuma-testleri': document.getElementById('okuma-testleri'),
    'dinleme-testleri': document.getElementById('dinleme-testleri'),
    'okuma-alistirmalar': document.getElementById('okuma-alistirmalar'),
    'dinleme-alistirmalar': document.getElementById('dinleme-alistirmalar'),
    'yazma-alistirmalar': document.getElementById('yazma-alistirmalar'),
    'a1-kelime': document.getElementById('a1-kelime'),
    'b2c1-kelime': document.getElementById('b2c1-kelime'),
    'yazma-sorulari': document.getElementById('yazma-sorulari'),
    'konusma-sorulari': document.getElementById('konusma-sorulari'),
    'okuma-metinleri': document.getElementById('okuma-metinleri'),
    'ekitaplar': document.getElementById('ekitaplar'),
    'oyunlar': document.getElementById('oyunlar'),
    'videolar': document.getElementById('videolar'),
    'ogretmenler-icin': document.getElementById('ogretmenler-icin')
  };
  const categoryMap = {
    'sinav': ['okuma-testleri','dinleme-testleri'],
    'alistirmalar': ['okuma-alistirmalar','dinleme-alistirmalar','yazma-alistirmalar'],
    'kelime': ['a1-kelime','b2c1-kelime'],
    'sorular': ['yazma-sorulari','konusma-sorulari'],
    'metin': ['okuma-metinleri','ekitaplar'],
    'oyunlar': ['oyunlar'],
    'video': ['videolar'],
    'ogretmen': ['ogretmenler-icin'],
    'odev': [] // ödev butonları zaten bağlı
  };
  const subLabels = {
    'sinav': [{id:'okuma-testleri',emoji:'📖',label:'Okuma sınavları'},{id:'dinleme-testleri',emoji:'🎧',label:'Dinleme sınavları'}],
    'alistirmalar': [{id:'okuma-alistirmalar',emoji:'✍️',label:'Okuma alıştırması'},{id:'dinleme-alistirmalar',emoji:'🎤',label:'Dinleme alıştırması'},{id:'yazma-alistirmalar',emoji:'✏️',label:'Yazma alıştırması'}],
    'kelime': [{id:'a1-kelime',emoji:'🗂️',label:'A1/A2 Kelime öğren'},{id:'b2c1-kelime',emoji:'📚',label:'B2/C1 kelime öğren'}],
    'sorular': [{id:'yazma-sorulari',emoji:'📝',label:'Yazma soruları'},{id:'konusma-sorulari',emoji:'💬',label:'Konuşma soruları'}],
    'metin': [{id:'okuma-metinleri',emoji:'📖',label:'Okuma metinleri'},{id:'ekitaplar',emoji:'📗',label:'E kitaplar Sesli kitaplar'}],
    'oyunlar': [{id:'oyunlar',emoji:'🎯',label:'Oyunlar'}],
    'video': [{id:'videolar',emoji:'🎬',label:'Videolar (Soru çözme teknikleri)'}],
    'ogretmen': [{id:'ogretmenler-icin',emoji:'👩‍🏫',label:'Öğretmenler için'}],
    'odev': []
  };
  const subArea = document.getElementById('subCategoryArea');
  const mainBtns = document.querySelectorAll('.cat-btn');
  let activeCategory = null;
  function renderSubs(category) {
    if(!category || !subLabels[category] || subLabels[category].length===0) { subArea.innerHTML=''; return; }
    let html = '<div class="sub-category-group">';
    subLabels[category].forEach(sub=>{
      html += `<button class="sub-cat-btn" data-sub-id="${sub.id}"><span class="sub-emoji">${sub.emoji}</span> ${sub.label}</button>`;
    });
    html += '</div>';
    subArea.innerHTML = html;
    document.querySelectorAll('.sub-cat-btn').forEach(btn=>{
      btn.addEventListener('click',(e)=>{
        e.stopPropagation();
        const subId = btn.getAttribute('data-sub-id');
        if(subId && panels[subId]) {
          Object.values(panels).forEach(p=>{ if(p) p.classList.remove('open'); p.style.maxHeight='0'; });
          const targetPanel = panels[subId];
          targetPanel.classList.add('open');
          targetPanel.style.maxHeight = targetPanel.scrollHeight + 'px';
          targetPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
          document.querySelectorAll('.sub-cat-btn').forEach(b=>b.classList.remove('active-sub'));
          btn.classList.add('active-sub');
        } else if(subId==='yazma-alistirmalar' && panels['yazma-alistirmalar']) { /* aynı işlem */ }
      });
    });
  }
  mainBtns.forEach(btn=>{
    btn.addEventListener('click',()=>{
      const cat = btn.getAttribute('data-cat');
      if(activeCategory===cat) { subArea.innerHTML=''; activeCategory=null; mainBtns.forEach(b=>b.classList.remove('active')); return; }
      mainBtns.forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = cat;
      renderSubs(cat);
      if(categoryMap[cat] && categoryMap[cat].length===1){
        const singleId = categoryMap[cat][0];
        if(panels[singleId]) {
          Object.values(panels).forEach(p=>{ if(p) p.classList.remove('open'); p.style.maxHeight='0'; });
          const targetPanel = panels[singleId];
          targetPanel.classList.add('open');
          targetPanel.style.maxHeight = targetPanel.scrollHeight + 'px';
          targetPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
}
window.addEventListener('pageshow',()=>{ closeModal(); targetVideoSrc=null; targetPage=''; targetUrl=''; });
(function() { const BASE_URL='https://countapi.mileshilliard.com/api/v1'; const TOTAL_KEY='hamzahoca-total-ziyaretci'; let visitorId=localStorage.getItem('hamzaVisitorId'); if(!visitorId){ visitorId='v_'+Math.random().toString(36).substr(2,9)+'_'+Date.now(); localStorage.setItem('hamzaVisitorId',visitorId); } const today=new Date().toISOString().split('T')[0]; const DAILY_KEY='hamzahoca-gunluk-'+today; const countedToday=localStorage.getItem('hamzaCountedDay')===today; async function updateCounters(){ try{ let dailyUrl; if(!countedToday){ dailyUrl=`${BASE_URL}/hit/${DAILY_KEY}`; localStorage.setItem('hamzaCountedDay',today); } else dailyUrl=`${BASE_URL}/get/${DAILY_KEY}`; const dailyRes=await fetch(dailyUrl); const dailyData=await dailyRes.json(); if(dailyData && (typeof dailyData.value==='number'||typeof dailyData.value==='string')) document.getElementById('vcDaily').textContent=dailyData.value; let totalUrl; if(!countedToday) totalUrl=`${BASE_URL}/hit/${TOTAL_KEY}`; else totalUrl=`${BASE_URL}/get/${TOTAL_KEY}`; const totalRes=await fetch(totalUrl); const totalData=await totalRes.json(); if(totalData && (typeof totalData.value==='number'||typeof totalData.value==='string')){ document.getElementById('vcTotal').textContent=totalData.value; localStorage.setItem('hamzaTotalEst',totalData.value); } } catch(e){ const localTotal=parseInt(localStorage.getItem('hamzaTotalEst')||'0'); document.getElementById('vcTotal').textContent=localTotal||'—'; document.getElementById('vcDaily').textContent='—'; } } updateCounters(); })();
