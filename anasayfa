<style>
/* ═══════════════════════════════════════
   RESET & BASE - AYNI
═══════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: linear-gradient(135deg, #0D1B2A 0%, #1a2a3a 100%);
  min-height: 100vh;
  color: white;
  position: relative;
}


.page-wrapper {
  max-width: 1100px;
  margin: 0 auto;
  padding: 48px 20px 80px;
}

/* ═══════════════════════════════════════
   HEADER
═══════════════════════════════════════ */
header {
  text-align: center;
  margin-bottom: 44px;
}

header h1 {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  font-size: clamp(1.8rem, 6vw, 2.5rem);
  font-weight: 800;
  color: #F5C842;
  line-height: 1.3;
  margin-bottom: 16px;
  letter-spacing: 0.02em;
}

.header-line {
  width: 80px;
  height: 2px;
  background: linear-gradient(90deg, transparent, #F5C842, transparent);
  margin: 0 auto 14px;
}

.stars {
  font-size: 1.2rem;
  color: #F5C842;
  letter-spacing: .4em;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
  letter-spacing: .1em;
  text-transform: uppercase;
}

/* ═══════════════════════════════════════
   BUTTON GRID (YENİ KATEGORİLER)
═══════════════════════════════════════ */
.btn-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 32px;
}

@media (max-width: 900px) { .btn-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 500px) { .btn-grid { grid-template-columns: 1fr; } }

/* Ana kategori butonları (üst düzey) */
.cat-btn {
  background: #1a2332;
  border: 2px solid #F5C842;
  border-radius: 16px;
  padding: 20px 10px;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  transition: background .22s, transform .18s, box-shadow .22s;
  width: 100%;
  justify-content: center;
}

.cat-btn:hover {
  background: #2a3a4a;
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}

.cat-btn.active {
  background: #2a3a4a;
  box-shadow: 0 0 0 1px #F5C842, 0 8px 24px rgba(0,0,0,0.4);
}

.cat-btn .emoji {
  font-size: 2rem;
  line-height: 1;
}

.cat-btn .label {
  font-size: clamp(0.9rem, 1.5vw, 1.1rem);
  font-weight: bold;
  color: #F5C842;
  text-align: center;
  line-height: 1.3;
}

/* Alt kategori grubu (butonun altında açılan ikincil butonlar) */
.sub-category-group {
  margin-top: 6px;
  margin-bottom: 20px;
  background: rgba(0,0,0,0.25);
  border-radius: 20px;
  padding: 12px 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}

.sub-cat-btn {
  background: #0f1722;
  border: 1px solid #F5C842;
  border-radius: 40px;
  padding: 8px 18px;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: all 0.2s;
  font-size: 0.85rem;
  font-weight: 600;
  color: #F5C842;
}

.sub-cat-btn .sub-emoji {
  font-size: 1.1rem;
}

.sub-cat-btn:hover {
  background: #F5C842;
  color: #0D1B2A;
  transform: translateY(-2px);
}

.sub-cat-btn.active-sub {
  background: #F5C842;
  color: #0D1B2A;
  border-color: #F5C842;
}

/* ═══════════════════════════════════════
   CONTENT PANEL
═══════════════════════════════════════ */
.content-panel {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height .45s cubic-bezier(.4,0,.2,1), opacity .35s ease, margin .3s ease;
  margin-bottom: 0;
  border-radius: 20px;
}

.content-panel.open {
  opacity: 1;
  margin-bottom: 16px;
}

.panel-header {
  background: #1a2332;
  padding: 16px 24px;
  border-radius: 20px 20px 0 0;
  border-bottom: 2px solid #F5C842;
}

.panel-header h2 {
  font-size: clamp(1.1rem, 2vw, 1.3rem);
  font-weight: bold;
  color: #F5C842;
}

.panel-body {
  background: white;
  padding: 24px;
  border-radius: 0 0 20px 20px;
}

.items-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 12px;
}

/* ═══════════════════════════════════════
   ITEM CARDS
═══════════════════════════════════════ */
.item-card {
  background: #f8f9fa;
  border: 1px solid #e9ecef;
  border-radius: 12px;
  padding: 12px 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  text-decoration: none;
  color: #333;
  font-size: 0.9rem;
  font-weight: 500;
  transition: background .2s, transform .15s;
}

.item-card:hover {
  background: #e9ecef;
  transform: translateX(5px);
  color: #333;
}

/* ═══════════════════════════════════════
   BADGES
═══════════════════════════════════════ */
.badge {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.7rem;
  font-weight: 600;
  white-space: nowrap;
  color: white;
}

.badge-locked { background: #6c757d; }
.badge-free   { background: #2a9d8f; }

/* ═══════════════════════════════════════
   B2/C1 TWO-COLUMN LAYOUT
═══════════════════════════════════════ */
.two-col-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

@media (max-width: 500px) {
  .two-col-grid { grid-template-columns: 1fr; }
}

.col-label {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  padding-bottom: 6px;
  margin-bottom: 4px;
}

.col-label-free {
  color: #2a9d8f;
  border-bottom: 2px solid #2a9d8f;
}

.col-label-locked {
  color: #6c757d;
  border-bottom: 2px solid #6c757d;
}

.col-items {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* ═══════════════════════════════════════
   LOGIN MODAL & OTHERS
═══════════════════════════════════════ */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0,0,0,0.8);
  align-items: center;
  justify-content: center;
}
.modal-overlay.show { display: flex; }
.modal { background: white; border-radius: 24px; padding: 40px; width: min(440px, 94vw); position: relative; animation: popIn .3s ease; }
.modal-close { position: absolute; top: 16px; right: 20px; background: none; border: none; font-size: 1.4rem; color: #aaa; cursor: pointer; }
.modal h2 { font-size: 24px; color: #333; margin-bottom: 6px; text-align: center; }
.modal .sub { font-size: 0.85rem; color: #888; text-align: center; margin-bottom: 28px; }
.form-group { margin-bottom: 18px; }
.form-group label { display: block; font-size: 0.82rem; color: #555; margin-bottom: 7px; font-weight: 600; }
.form-group input { width: 100%; border: 2px solid #ddd; border-radius: 10px; padding: 12px 14px; outline: none; }
.form-group input:focus { border-color: #F5C842; }
.btn-login { width: 100%; padding: 14px; background: linear-gradient(135deg, #F5C842, #C9960A); border: none; border-radius: 40px; color: white; font-weight: 700; cursor: pointer; }
.error-msg { background: #fff0f0; border: 1px solid #f8c8c8; border-radius: 8px; padding: 10px 14px; color: #d63031; font-size: 0.85rem; margin-top: 14px; display: none; text-align: center; }
.error-msg.show { display: block; }

/* ═══════════════════════════════════════
   FOOTER
═══════════════════════════════════════ */
footer {
  margin-top: 60px;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8px;
  position: relative;
}
footer p { text-align: center; }
footer span { color: #F5C842; }

/* ═══════════════════════════════════════
   VISITOR COUNTER
═══════════════════════════════════════ */
.visitor-counter {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(245,200,66,0.3);
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 0.75rem;
}

.visitor-counter .vc-icon {
  font-size: 0.8rem;
}

.visitor-counter .vc-divider {
  color: rgba(245,200,66,0.4);
  margin: 0 1px;
}

.visitor-counter .vc-daily {
  color: #F5C842;
  font-weight: 700;
}

.visitor-counter .vc-total {
  color: #F5C842;
  font-weight: 700;
}

@keyframes popIn {
  from { opacity: 0; transform: scale(.93) translateY(10px); }
  to   { opacity: 1; transform: none; }
}

/* ═══════════════════════════════════════
   TELEGRAM WIDGET
═══════════════════════════════════════ */
.tg-widget {
  display: flex;
  align-items: flex-end;
  gap: 12px;
  margin-top: 20px;
  padding: 16px 18px;
  background: #f0f4ff;
  border-radius: 16px;
  border: 1px solid #d0dcf8;
}

.tg-icon {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  background: #229ED9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tg-icon svg {
  width: 24px;
  height: 24px;
  fill: white;
}

.tg-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.tg-bubble {
  background: #229ED9;
  color: white;
  font-size: 0.88rem;
  font-weight: 500;
  padding: 10px 14px;
  border-radius: 16px 16px 16px 4px;
  line-height: 1.4;
  display: inline-block;
  max-width: 100%;
}

.tg-send-btn {
  align-self: flex-start;
  background: linear-gradient(135deg, #229ED9, #1a7fb5);
  color: white;
  border: none;
  border-radius: 20px;
  padding: 7px 18px;
  font-size: 0.78rem;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: transform .15s, box-shadow .15s;
  text-decoration: none;
  letter-spacing: 0.03em;
}

.tg-send-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(34,158,217,0.4);
}

.tg-send-btn svg {
  width: 14px;
  height: 14px;
  fill: white;
}

/* LOGO */
.site-logo {
  position: absolute;
  top: 20px;
  width: auto;
  height: auto;
  max-width: 130px;
  max-height: 130px;
  z-index: 50;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
  pointer-events: none;
}

.site-logo.left {
  left: 20px;
}

.site-logo.right {
  right: 20px;
}

@media (max-width: 1100px) {
  .site-logo {
    max-width: 100px;
    max-height: 100px;
  }
  .site-logo.left { left: 15px; top: 15px; }
  .site-logo.right { right: 15px; top: 15px; }
}
@media (max-width: 700px) {
  .site-logo {
    max-width: 70px;
    max-height: 70px;
  }
  .site-logo.left { left: 10px; top: 10px; }
  .site-logo.right { right: 10px; top: 10px; }
}
@media (max-width: 500px) {
  .site-logo {
    max-width: 55px;
    max-height: 55px;
  }
}

.site-logo img {
  width: 100%;
  height: auto;
  display: block;
  background: transparent;
  border: none;
  box-shadow: none;
}

</style>
</head>
